# Copy this file to `.env` in the repo root and fill in real values.
# Never commit `.env` — it is listed in .gitignore.

# Backend (ASP.NET Core environment variable names)
ConnectionStrings__DefaultConnection=
Jwt__Secret=
Jwt__Issuer=IdeaSparringPartner
Jwt__Audience=IdeaSparringPartnerClient
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7
Ai__Provider=Gemini
Ai__GeminiApiKey=
Ai__Model=gemini-2.5-flash
FrontendUrl=http://localhost:4300

# Frontend (local reference only; Angular uses environment.ts for dev)
API_BASE_URL=http://localhost:5080/api
BACKEND_URL=http://localhost:5080
